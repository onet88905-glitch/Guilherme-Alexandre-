on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  verificacoes-basicas:
    runs-on: ubuntu-latest

    steps:
      - name: Baixando o codigo
        uses: actions/checkout@v4

      - name: Verificando arquivos
        run: |
          echo "Arquivos do projeto:"
          ls -la

      - name: Configurando Node
        uses: actions/setup-node@v4
        with:
          node-version: '18'

      - name: Executando aplicacao
        run: |
          echo "Iniciando aplicacao..."
          node app.js

      - name: Sucesso
        run: echo "Pipeline funcionando!"
